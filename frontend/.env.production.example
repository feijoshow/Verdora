# Production overrides — copy to .env.production (gitignored)
# Used by Vercel builds and `npm run eas:preview` when VERDORA_API_URL is unset.

# Hosted Verdora API on Render (no trailing slash)
EXPO_PUBLIC_AI_API_URL=https://verdora-api.onrender.com

# Optional: leave direct AI keys empty when using the API proxy
# EXPO_PUBLIC_ZAI_API_KEY=
# EXPO_PUBLIC_GROK_API_KEY=
