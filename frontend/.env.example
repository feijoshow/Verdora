# Verdora environment — copy to .env

# Supabase (required) — project: https://wfkciaoxqqwleybyvisp.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://wfkciaoxqqwleybyvisp.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Local AI proxy — chat + scanner only (run: npm run api:dev)
# When set, API keys live in api/.env — leave direct keys below empty.
EXPO_PUBLIC_AI_API_URL=http://localhost:3001

# Full REST backend (optional — auth/calendar/admin; not needed for local dev)
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com

# OpenWeather — live weather forecasts (Weather tab)
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# Grok (xAI) — only if NOT using EXPO_PUBLIC_AI_API_URL (browser direct call)
EXPO_PUBLIC_GROK_API_KEY=

# Z.ai — crop scanner (GLM-4.6V-Flash); only if NOT using EXPO_PUBLIC_AI_API_URL
# Get from https://z.ai/model-api — put server-side copy in api/.env as ZAI_API_KEY
EXPO_PUBLIC_ZAI_API_KEY=

# Gemini — legacy/unused while quota exhausted; optional fallback
# Get from https://aistudio.google.com/apikey — AIzaSy... (legacy) or AQ.... (auth keys)
EXPO_PUBLIC_GEMINI_API_KEY=

# Demo / tester build (optional)
# EXPO_PUBLIC_DEMO_MODE=1
# EXPO_PUBLIC_FEEDBACK_EMAIL=cristianofeijon@gmail.com

# Expo offline mode if fetch fails during start
# EXPO_OFFLINE=1
