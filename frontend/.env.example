# Verdora environment — copy to .env

# Supabase (required) — run backend/supabase/schema.sql first
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional REST API (if you deploy a separate Verdora backend)
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com

# OpenWeather (optional — live weather forecasts)
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# Gemini (optional — AI farming assistant)
EXPO_PUBLIC_GEMINI_API_KEY=

# Expo offline mode if fetch fails during start
# EXPO_OFFLINE=1
