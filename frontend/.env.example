# Verdora environment — copy to .env

# Supabase (required) — project: https://wfkciaoxqqwleybyvisp.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://wfkciaoxqqwleybyvisp.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ── AI backend (pick ONE approach) ──────────────────────────────────────────
#
# A) Local dev — run `npm run api:dev` from repo root:
EXPO_PUBLIC_AI_API_URL=http://localhost:3001
#
# B) Production (Render + EAS/Vercel) — copy .env.production.example → .env.production:
# EXPO_PUBLIC_AI_API_URL=https://verdora-api.onrender.com
#
# C) Direct keys on device (fallback if no API URL) — not recommended for production:
# EXPO_PUBLIC_ZAI_API_KEY=
# EXPO_PUBLIC_GROK_API_KEY=

# OpenWeather — live weather forecasts (Weather tab)
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# Gemini — legacy/unused
# EXPO_PUBLIC_GEMINI_API_KEY=

# Demo / tester build (optional)
# EXPO_PUBLIC_DEMO_MODE=1
# EXPO_PUBLIC_FEEDBACK_EMAIL=you@example.com
