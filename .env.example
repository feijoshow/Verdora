# Verdora environment — copy to .env and adjust

# Backend REST API (when deployed)
EXPO_PUBLIC_API_URL=https://api.verdora.mock

# Set to "false" to call real APIs (requires working backend/network)
EXPO_PUBLIC_USE_MOCK_API=true

# Third-party keys (optional — used when mock mode is off)
EXPO_PUBLIC_OPENWEATHER_API_KEY=your_openweather_key
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_key

# Future Supabase auth migration
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# If `npm start` fails with "TypeError: fetch failed", Node cannot reach api.expo.dev.
# npm start already uses --offline; or set:
# EXPO_OFFLINE=1
# EXPO_NO_DEPENDENCY_VALIDATION=1
