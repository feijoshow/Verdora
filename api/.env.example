# Verdora API — copy to .env (never commit)

PORT=3001

# Grok chat (xAI) — https://console.x.ai/ (team needs credits/licenses)
XAI_API_KEY=

# Z.ai crop scanner (GLM-4.6V-Flash) — https://z.ai/model-api
ZAI_API_KEY=

# Optional overrides
# ZAI_VISION_MODEL=glm-4.6v-flash
# ZAI_CHAT_MODEL=glm-4.7-flash

# Legacy Gemini (unused while quota exhausted)
# GEMINI_API_KEY=

# Comma-separated browser origins (Expo web default shown)
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
