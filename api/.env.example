# Verdora API — copy to .env (never commit)

PORT=3001

# Grok chat (xAI) — https://console.x.ai/
XAI_API_KEY=

# Z.ai crop scanner (GLM-4.6V-Flash) — https://z.ai/model-api
ZAI_API_KEY=

# Optional overrides
# ZAI_VISION_MODEL=glm-4.6v-flash
# ZAI_CHAT_MODEL=glm-4.7-flash

# Browser origins (Expo web + Vercel). Native apps do not send Origin.
# Add your Vercel URL after deploy, e.g. https://verdora.vercel.app
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:8082,https://verdora-sepia.vercel.app

# Password reset emails (Resend + Supabase admin OTP)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM="Verdora <onboarding@resend.dev>"
